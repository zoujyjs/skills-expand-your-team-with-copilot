{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",
  "forwardPorts": [8000],
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13"
    }
  },
  "postCreateCommand": "bash ./.devcontainer/postCreate.sh",
  "postStartCommand": "bash ./.devcontainer/postStart.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "ms-python.python",
        "ms-python.debugpy"
      ]
    }
  }
}
